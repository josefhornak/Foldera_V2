# Server
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:5173

# Database
DATABASE_URL=postgres://foldera:foldera@localhost:5432/foldera_v2

# Valkey / Redis (BullMQ, OAuth state)
REDIS_URL=redis://localhost:6379

# Auth — min 32 chars
JWT_SECRET=change-me-to-a-long-random-secret-string

# AES-256-GCM key for stored credentials (IMAP passwords, OAuth tokens, ABRA passwords)
# Generate: openssl rand -hex 32
APP_ENCRYPTION_KEY=

# Mistral OCR
MISTRAL_API_KEY=
MISTRAL_API_URL=https://api.mistral.ai

# OAuth providers (optional — enables OneDrive / Google Drive sources)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Polling intervals (minutes)
SOURCE_POLL_INTERVAL_MIN=5
